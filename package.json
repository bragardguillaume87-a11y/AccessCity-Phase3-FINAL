{
  "name": "accesscity-phase5",
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:unit": "vitest",
    "test:unit:watch": "vitest --watch",
    "test:unit:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "format:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "predev:vite": "node tools/generate-assets-manifest.js",
    "dev:vite": "vite --config vite.config.js",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:server\" --names \"VITE,SERVER\" --prefix-colors \"cyan,magenta\"",
    "prebuild:vite": "node tools/generate-assets-manifest.js",
    "build:vite": "vite build --config vite.config.js",
    "build:player": "vite build --config vite.config.player.ts",
    "dev:player-tauri": "vite --config vite.config.player-tauri.ts --port 5174",
    "build:player-tauri-frontend": "vite build --config vite.config.player-tauri.ts",
    "build:player-exe": "npm run build:player-tauri-frontend && npx tauri build --config src-tauri/tauri.conf.json",
    "dev:editor-tauri": "vite --config vite.config.editor-tauri.ts --port 5173",
    "prebuild:editor-tauri-frontend": "node tools/generate-assets-manifest.js",
    "build:editor-tauri-frontend": "vite build --config vite.config.editor-tauri.ts",
    "build:editor-exe": "npm run build:editor-tauri-frontend && npx tauri build --config src-tauri/tauri.conf.editor.json",
    "build:portable": "npm run build:editor-tauri-frontend && npx tauri build --config src-tauri/tauri.conf.portable.json && powershell -ExecutionPolicy Bypass -File tools/package-portable.ps1",
    "build:vite:coverage": "set VITE_COVERAGE=true && vite build --config vite.config.js",
    "preview:vite": "vite preview --config vite.config.js",
    "e2e:vite": "npm run build:vite:coverage && vite preview --port 8000 & playwright test --config=playwright.config.vite.ts",
    "e2e:install": "playwright install --with-deps",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "coverage:html": "c8 --reporter=html npm test",
    "coverage:merge": "node tools/merge_coverage.cjs",
    "coverage:reports": "node tools/generate_reports.cjs",
    "summary": "node tools/generate_summary.js --help",
    "install:server": "cd server && npm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@sentry/vite-plugin": "^4.7.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/dagre": "^0.7.53",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.22",
    "c8": "^9.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.0",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.5",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.19",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excaliburjs/plugin-ldtk": "^0.32.0",
    "@hookform/resolvers": "^5.2.2",
    "@measured/puck": "^0.20.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/react": "^10.36.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@tauri-apps/api": "^2.10.1",
    "@xyflow/react": "^12.10.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "excalibur": "^0.32.0",
    "fflate": "^0.8.2",
    "framer-motion": "^12.23.26",
    "immer": "^11.1.0",
    "jsfxr": "^1.4.0",
    "konva": "^10.2.0",
    "lucide-react": "^0.561.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "^6.0.2",
    "react-hook-form": "^7.69.0",
    "react-konva": "^19.2.3",
    "react-resizable-panels": "^4.0.13",
    "react-rnd": "^10.5.2",
    "react-zoom-pan-pinch": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "use-sync-external-store": "^1.6.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zundo": "^2.3.0",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "@xyflow/react": {
      "zustand": "^5.0.9"
    },
    "@radix-ui/react-dismissable-layer": "1.1.11",
    "@radix-ui/react-focus-scope": "1.1.8",
    "@radix-ui/react-portal": "1.1.10",
    "@radix-ui/react-primitive": "2.1.4"
  }
}
