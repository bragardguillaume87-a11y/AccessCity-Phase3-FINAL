{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AccessCity Studio",
  "version": "1.0.0",
  "identifier": "fr.accesscity.studio",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite",
    "frontendDist": "../dist-editor-tauri"
  },
  "app": {
    "windows": [
      {
        "title": "AccessCity Studio",
        "width": 1600,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost https://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; worker-src blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "languages": ["French"]
      }
    }
  }
}
